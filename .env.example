PLATFORM_DEBUG=true
PLATFORM_LOG_LEVEL=INFO
PLATFORM_HOST=0.0.0.0
PLATFORM_PORT=8088
PLATFORM_DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/platform
PLATFORM_REDIS_URL=redis://redis:6379/0
PLATFORM_LLM_PROVIDER=openai
PLATFORM_LLM_DEFAULT_MODEL=gpt-4o
PLATFORM_LLM_BASE_URL=https://api.openai.com/v1
PLATFORM_LLM_API_KEY=
PLATFORM_LLM_ORGANIZATION=
PLATFORM_LLM_TIMEOUT_SECONDS=60
PLATFORM_LLM_MAX_RETRIES=3
PLATFORM_VECTOR_STORE_TYPE=chroma
PLATFORM_CHROMA_PERSIST_DIR=./data/chroma
PLATFORM_PINECONE_API_KEY=
PLATFORM_PINECONE_INDEX=
PLATFORM_MCP_SERVERS={"browser":"http://127.0.0.1:17002","filesystem":"http://127.0.0.1:17001"}
PLATFORM_EMBEDDING_MODEL=text-embedding-3-small
PLATFORM_JWT_SECRET=change-me
PLATFORM_API_KEYS=dev-key
PLATFORM_API_KEY_HEADER=X-API-Key
PLATFORM_CORS_ORIGINS=["*"]
PLATFORM_ENABLE_TRACING=true
